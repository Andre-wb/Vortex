# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual Environment
.venv/
venv/
env/

# Environment / Secrets
.env
.env.*
!.env.example

# Database
*.db
*.db-shm
*.db-wal
*.db-journal
file::memory:
:file::memory:

# User Data — matches these dirs anywhere in the tree (e.g. runtime
# uploads/ written under static/ or Gravitix/). The `!app/keys/` line
# carves out the Python package from the broad `keys/` rule so source
# files like app/keys/prekeys.py stay tracked.
uploads/
keys/
!app/keys/
certs/
backups/
logs/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.project
.settings/

# Testing / Coverage
.pytest_cache/
htmlcov/
.coverage
coverage.xml
coverage/
test-results/
*.cover
.hypothesis/
.tox/

# Linting / Type Checking
.ruff_cache/
.mypy_cache/
.dmypy.json

# Rust
debug/
target/
**/*.rs.bk
*.pdb
**/mutants.out*/

# Node
node_modules/
package-lock.json

# Anchor / Solana build artifacts
.anchor/
test-ledger/
solana_program/target/
solana_program/target/idl/
solana_program/target/types/
solana_program/target/deploy/*.json
!solana_program/target/deploy/vortex_registry-keypair.json.example

# Wizard user-state (desktop app writes env + keys into OS-standard dirs;
# when developing in-tree we sometimes point it at ./local/ instead)
.vortex/
vortex_wizard/dist/
vortex_wizard/build/
vortex_wizard/.vortex/

# 24-word recovery phrases — anything that looks like a seed download
# must never be committed. The wizard's "Download .txt" button writes
# vortex-seed.txt in particular.
vortex-seed.txt
*-seed.txt
*-mnemonic.txt
mnemonic-*.txt
seed-phrase*.txt

# Docker
docker-compose.override.yml

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Media (large files)
*.mp4
*.mov
*.avi
*.jpg
*.jpeg
!logo/
!logo/*
!static/favicon.ico
!static/icons/

# Misc
*.tmp
*.bak
*.log
global_peers.json
bandit-report.json

# AI models
Qwen3-8B/
