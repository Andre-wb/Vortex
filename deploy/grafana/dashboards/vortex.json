      "title": "Status",
      "type": "stat",
      "targets": [
        { "expr": "up{job=\"vortex\"}", "legendFormat": "Status", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
