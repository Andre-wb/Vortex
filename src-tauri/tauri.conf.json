{
  "$schema": "https://raw.githubusercontent.com/nicbarker/tauri-schema/main/tauri.conf.schema.json",
  "productName": "Vortex Chat",
  "version": "5.0.0",
  "identifier": "com.vortex.chat",
  "build": {
    "frontendDist": "../static",
    "devUrl": "http://localhost:9000",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "title": "Vortex Chat",
    "windows": [
      {
        "title": "Vortex Chat",
        "width": 1200,
        "height": 800,
        "minWidth": 400,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "url": "http://localhost:9000"
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:* ws://localhost:* wss://localhost:*; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' http://localhost:* ws://localhost:* wss://localhost:*"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Vortex Chat"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null
    },
    "windows": {
      "wix": null,
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "notification": {
      "all": true
    },
    "autostart": {
      "all": true
    },
    "global-shortcut": {
      "all": true
    },
    "dialog": {
      "all": true
    },
    "clipboard-manager": {
      "all": true
    },
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["vortex"]
      }
    }
  }
}
